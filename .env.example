# Optional overrides for local tools. Values are examples, not credentials.
SYNTHDET_CONFIG=configs/project.yaml
SYNTHDET_HOST=127.0.0.1
SYNTHDET_PORT=8000
SYNTHDET_DEVICE=auto

# Required only for automatic Roboflow dataset export. Never commit the real value.
ROBOFLOW_API_KEY=replace_with_your_roboflow_private_api_key
